DATABASE_URL="super:secret@localhost:5432/mydb"
# Signs session tokens. REQUIRED in production (the app throws at startup if
# unset); a dev-only fallback is used with a warning when NODE_ENV !== production.
# Generate one with: openssl rand -hex 32
JWT_SECRET="your_long_random_secret_here"
# Admin login provisioning. There is NO default admin — `npm run db:seed` creates
# the admin ONLY when both are set (and never resets an existing admin's
# password). Set these locally to get an admin; in prod set them as deploy
# secrets. To rotate later: `npm run set-admin-password` (reads these + DATABASE_URL).
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="a_long_admin_passphrase_min_12_chars"
NEXT_PUBLIC_CF_IMAGES_BASE_URL="https://imagedelivery.net/YOUR_ACCOUNT_HASH"
CF_API_TOKEN="your_cloudflare_token_here"
# Stripe secret key for Checkout. Use a TEST key (sk_test_… or rk_test_…) in
# dev; never commit a real value. Without it, /api/checkout returns 503.
STRIPE_SECRET_KEY="sk_test_your_stripe_test_key"
# Public site origin used for Stripe success/cancel URLs. Falls back to the
# request origin if unset (fine for local dev); set it in production.
SITE_URL="http://localhost:3000"
# Verifies Stripe webhook signatures at /api/stripe/webhook. Locally, use the
# whsec_… printed by `stripe listen`; in prod, the Dashboard endpoint's secret.
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"
# Protects the scheduled sweep at /api/cron/expire-orders. Vercel Cron sends it
# as `Authorization: Bearer <CRON_SECRET>` automatically when set on the project.
CRON_SECRET="a_long_random_value"
# Transactional email (Resend) for order confirmations, sent on the paid webhook.
# Dormant if EITHER is unset: the email is rendered and logged, never sent — no
# crash. EMAIL_FROM must be an address on a domain verified with Resend (SPF/DKIM).
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="Slater Street Candles <orders@your-verified-domain.com>"
# Feature flags (fail-closed: on only when exactly "true"). Leave unset in prod
# to keep the commerce surface hidden. Set BOTH locally to work on checkout.
NEXT_PUBLIC_ENABLE_ECOMMERCE="true"  # product browsing, cart, /api/cart
NEXT_PUBLIC_ENABLE_CHECKOUT="true"   # checkout button + /api/checkout (payment)
# Notion internal-integration token for `npm run ticket SSC-<n>` (resolves a board
# ticket by number over the REST API — WORKFLOW.md). Create one at
# https://www.notion.so/my-integrations, share the Project Board with it, paste it
# here. Only used by the CLI helper; unset = the helper prints a setup hint.
NOTION_API_KEY="ntn_your_notion_integration_token"

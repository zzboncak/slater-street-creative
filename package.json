{
  "name": "slater-street-creative",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:db": "bash scripts/dev.sh",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:seed": "tsx prisma/seed.ts",
    "set-admin-password": "tsx scripts/set-admin-password.ts",
    "ticket": "tsx scripts/notion-ticket.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.13.0",
    "next": "^15.5.5",
    "prisma": "^6.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.1",
    "stripe": "^22.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.20",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}

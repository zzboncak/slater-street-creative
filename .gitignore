# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the placeholder template IS committed — it's the documented setup guide
# every doc points at ("see .env.example"). Real .env / .env.local stay ignored.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# vscode
.vscode/*

# jetbrains
.idea/

# Ignore workspace-specific GitHub files (e.g. copilot instructions) but keep
# CI workflows committable.
.github/*
!.github/workflows/
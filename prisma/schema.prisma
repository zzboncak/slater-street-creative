// Prisma schema for Slater Street Candles

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER // was USER, renamed in the SSC-36 migration (relabel, keeps its slot)
  FULFILLMENT // ships orders: viewOrders + fulfillOrders only (see src/lib/authz.ts)
}

enum ProductType {
  CANDLE
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  FULFILLED
  CANCELLED
  EXPIRED // a PENDING order swept as abandoned (never paid) — see SSC-26
}

model Product {
  id            String     @id @default(cuid())
  name          String
  description   String?
  priceCents    Int        // price stored in cents
  image         String?
  type          ProductType @default(CANDLE)
  active        Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  inventory   Inventory?
  orderItems  OrderItem[]
  scents      ProductScent[] // scent notes, via the join (SSC-32)
}

// A scent note as a first-class, admin-managed entity (SSC-32). `slug` is the
// unique integrity key (normalized name) so casing/whitespace variants can't
// duplicate; `active` soft-hides a note from new use without breaking history.
model Scent {
  id        String   @id @default(cuid())
  name      String // display form, e.g. "Blue Spruce"
  slug      String   @unique // normalized key, e.g. "blue-spruce"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductScent[]
}

// Explicit Product<->Scent join. Composite PK forbids duplicate links; `position`
// preserves a candle's curated note order. Deleting a product cascades its links;
// a scent still in use can't be deleted (Restrict) — that's the integrity win.
model ProductScent {
  productId String
  scentId   String
  position  Int // 0-based order of this note on the product

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  scent   Scent   @relation(fields: [scentId], references: [id], onDelete: Restrict)

  @@id([productId, scentId])
  @@index([scentId])
}

model Inventory {
  id        String   @id @default(cuid())
  productId String   @unique
  quantity  Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  // optional link to User (1:1)
  user       User?
  orders     Order[]
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  percentOff  Int?     // 0-100
  amountOff   Int?     // cents
  active      Boolean  @default(true)
  validFrom   DateTime?
  validTo     DateTime?
  createdAt   DateTime @default(now())

  // Redemption limits (SSC-30). All null/false = unchanged legacy behavior.
  maxRedemptions  Int? // global cap on total redemptions; null = unlimited
  perUserLimit    Int? // per-customer cap for THIS coupon; null = unlimited
  usedCount       Int     @default(0) // reserve-and-release redemption counter
  allowFreeOrders Boolean @default(false) // may this coupon drive a total to $0?
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  role         Role      @default(CUSTOMER)

  customerId   String?   @unique
  customer     Customer? @relation(fields: [customerId], references: [id])

  sessions     Session[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
}

model Order {
  id String @id @default(cuid())

  // Who ordered: nullable customer link (guest checkout) + email snapshot.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  email      String

  status OrderStatus @default(PENDING)

  // Money — integer cents, snapshot at order time.
  subtotalCents Int
  discountCents Int @default(0)
  totalCents    Int

  // Coupon snapshot (preserved even if the coupon later changes/deletes).
  couponCode       String?
  couponPercentOff Int?
  couponAmountOff  Int?

  // Shipping address snapshot (embedded; nullable — set at checkout).
  shipName       String?
  shipLine1      String?
  shipLine2      String?
  shipCity       String?
  shipState      String?
  shipPostalCode String?
  shipCountry    String?

  stripeCheckoutSessionId String? @unique // webhook idempotency

  // Client-supplied checkout idempotency token (SSC-28): a retry with the same
  // token reuses this order instead of minting a duplicate PENDING one. Nullable
  // — tokenless requests and pre-SSC-28 orders simply don't dedup.
  checkoutToken String? @unique

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     OrderItem[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Convenience link, nullable + SetNull so deleting a product keeps history.
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // Snapshots — so later product edits/deletes don't rewrite order history.
  name           String
  unitPriceCents Int
  quantity       Int
  lineTotalCents Int

  @@index([orderId])
}
